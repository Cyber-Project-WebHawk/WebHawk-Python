# ---- Environment & Secrets (CRITICAL — never commit these) ----
.env
.env.*
!.env.example
.envrc
*.pem
*.key
*.crt
secrets.json
secrets.yaml
secrets.toml

# ---- Flask ----
instance/
.webassets-cache
flask_session/

# ---- JWT / Auth ----
# Don't commit any generated token files or key material
jwt_secret*
private_key*
public_key*

# ---- PostgreSQL ----
*.sql.bak
pg_data/          # local Postgres data volume (used in Docker)
postgres-data/

# ---- Redis ----
*.rdb
*.aof
*.pid
redis-data/       # local Redis data volume (used in Docker)
dump.rdb

# ---- Docker ----
# Keep docker-compose.yml, but ignore local override and volumes
docker-compose.override.yml
docker-compose.local.yml
.docker/
volumes/

# ---- Logs & Security Logs ----
*.log
logs/
security_logs/    # sensitive — don't commit attack logs

# ---- Testing ----
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/
nosetests.xml
*.cover
*.py.cover
cover/

# ---- Postman (keep the collection, ignore env files with secrets) ----
postman_environment*.json   # contains base URLs, API keys, tokens

# ---- Type checkers & linters ----
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
